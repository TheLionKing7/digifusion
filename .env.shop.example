# ─────────────────────────────────────────────────────────────
# DigiFusion Shop — environment variables
# Copy to .env.local for dev, paste into your hosting provider for prod.
# ─────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://digifusion.ai

# ── Supabase (DB) ─────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ── Cloudflare R2 (downloads) ─────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_SHOP_BUCKET=digifusion-shop

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Flutterwave ───────────────────────────────
FLW_SECRET_KEY=FLWSECK-...
FLW_WEBHOOK_HASH=                    # any random string; set the same in Flutterwave dashboard

# ── OPay ──────────────────────────────────────
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_BASE_URL=https://liveapi.opaycheckout.com

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_...
SHOP_FROM_EMAIL=shop@digifusion.ai

# ── Admin gate (Basic Auth on /admin/*) ───────
ADMIN_USER=boroji
ADMIN_PASSWORD=                      # pick a strong random string
